  "scripts": {
    "watch-js": "npx babel src/kaleidoscope-js --out-dir kaleidoscope-js --watch",
    "watch": "shadow-cljs watch app stories kaleidoscope.pub",
    "build-release": "shadow-cljs release app kaleidoscope.pub",
    "deploy": "./scripts/deployment/deploy-to-s3",
    "bump": "shadow-cljs run deploy.bump-version/increment",
    "pack": "webpack --watch",
    "storybook": "storybook dev -s '../resources/kaleidoscope.client/static/js/compiled/shareable_stories' -p 6006",
