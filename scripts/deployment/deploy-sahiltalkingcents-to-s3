#!/bin/bash


SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" &>/dev/null && pwd)

pushd "$SCRIPT_DIR/../../"

echo "Deploying frontend to sahiltalkingcents bucket..."

aws s3 sync resources/sahiltalkingcents.com/static s3://sahiltalkingcents.com/static \
    --delete \
    --exclude "*/cljs-runtime/*" \
    --exclude "*/shareable_stories/*" # --dryrun

popd
